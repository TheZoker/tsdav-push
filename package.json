{
  "name": "tsdav-webdav-push",
  "version": "0.1.0",
  "description": "WebDAV Push client helpers for tsdav-based applications",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "webdav",
    "caldav",
    "carddav",
    "push",
    "tsdav"
  ],
  "peerDependencies": {
    "tsdav": ">=2.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0"
  }
}